# Optional. If set, every agent reasons with Claude (via langchain-anthropic)
# instead of the deterministic rule-based fallback. The pipeline runs fine
# with this unset -- it just uses the heuristics in each agent file instead.
ANTHROPIC_API_KEY=

# Optional. Controls which data backend tools.py uses: "json" (flat mock
# files in mock_data/) or "sqlite" (real database at database/supply_chain.db,
# built by running `python db_setup.py`). If unset, it auto-detects: sqlite
# if the database file exists, otherwise json.
DATA_BACKEND=
